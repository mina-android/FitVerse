# Firebase Web Config
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=fitverse-6513c.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=fitverse-6513c
VITE_FIREBASE_STORAGE_BUCKET=fitverse-6513c.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
